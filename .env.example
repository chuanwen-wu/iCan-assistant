# Copy to .env (same directory) and fill in. .env is gitignored.
# Used by scripts/lark-mcp.sh to launch the Feishu/Lark MCP server.

FEISHU_APP_ID=cli_xxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxx

# Optional: point the launcher at a specific .env instead of auto-discovery.
# FEISHU_ENV_FILE=/absolute/path/to/.env

# Optional: override MCP tool presets / language.
# FEISHU_MCP_TOOLS=preset.im.default,preset.calendar.default,preset.doc.default,preset.task.default
# FEISHU_MCP_LANG=zh
